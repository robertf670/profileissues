# Copy to .env and fill in as needed.

# Optional: NTA developer portal key (Ocp-Apim-Subscription-Key) if using an API-hosted GTFS URL.
NTA_API_KEY=

# Optional: override default public TFI Dublin Bus static GTFS zip.
GTFS_DOWNLOAD_URL=https://www.transportforireland.ie/transitData/Data/GTFS_Dublin_Bus.zip

# Optional: set to 1 to hide the sidebar "Route scan" block (local or Streamlit secrets).
# HIDE_ROUTE_SCAN=
